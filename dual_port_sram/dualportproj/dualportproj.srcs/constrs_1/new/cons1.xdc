# ---------------------------------------------------------------------------
# 0. 물리적 속성 설정
# ---------------------------------------------------------------------------
# 특정 비트 대신 전체 출력 포트(rd)에 대해 Drive Strength를 설정하는 것이 좋습니다.
set_property DRIVE 12 [get_ports {rd[*]}]
set_property SLEW SLOW [get_ports {rd[*]}]

# ---------------------------------------------------------------------------
# 1. 클럭 정의 (Clock Definition)
# 주석의 의도대로 10ns (100MHz)로 수정하였습니다.
# ---------------------------------------------------------------------------
create_clock -period 10.000 -name clk -waveform {0.000 5.000} [get_ports clk]

# ---------------------------------------------------------------------------
# 2. 입출력 타이밍 예산 설정 (I/O Budgeting)
# ---------------------------------------------------------------------------
# 입력 포트 -> 내부 레지스터 (Setup Margin 확보)
# 10ns 주기의 40%인 4.0ns를 할당
set_max_delay -from [get_ports {wa[*] wd[*] we ra[*] re}] -to [all_registers -data_pins] -datapath_only 8.0

# 내부 레지스터 -> 출력 포트 (rd)
set_max_delay -from [all_registers -clock_pins] -to [get_ports {rd[*]}] -datapath_only 8.0

# ---------------------------------------------------------------------------
# 3. 클럭 불확실성 및 지터 설정
# ---------------------------------------------------------------------------
set_system_jitter 0.0
# 이제 create_clock이 성공하므로 아래 명령이 정상 작동합니다.
set_clock_uncertainty 0.100 [get_clocks clk]
set_clock_latency -source -max 0.20 [get_clocks clk]