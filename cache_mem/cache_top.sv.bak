
// Direct-mapped Cache memory м„Өкі„ 

module cache_256B #(
    parameter int MEM_SIZE = 256,   // Memoryмқҳ Size                    2 Tag bits (8-2-4)
    parameter int BLK_SIZE = 4,     // Blockмқҳ Size                     2 offset bits
    parameter int CACHE_SIZE = 16,  // Cacheмқҳ Size                     4 index bits
    
    parameter int INDEX = $clog2(CACHE_SIZE),
    parameter int OFFSET = $clog2(BLK_SIZE),
    parameter int TAG = ADDR_WIDTH - INDEX - OFFSET,

    parameter int DATA_WIDTH = BLK_SIZE*8,          // bitлЎң кі„мӮ°н•ҙм„ң нҢҗлӢЁн•ҙм•ј н•Ё. BLK Sizeк°Җ н•ҳлӮҳмқҳ Cachelineм—җ лӘҮ к°ңмқҳ DATAк°Җ м ҖмһҘлҗ  мҲҳ мһҲлҠ”к°ҖлҘј м„Өм •н•ҳлҠ” кІғ.
    parameter int ADDR_WIDTH = $clog2(MEM_SIZE),    
    parameter int CELL_DEPTH = CACHE_SIZE,          // indexк°Җ к°ҖлҰ¬нӮ¬ мҲҳ мһҲлҠ” мҙқ line мҲҳ. Direct Mappedлқјм„ң к·ёлғҘ CACHE SIZEлЎң л°”лЎң мӮҪмһ…н•Ё.

    parameter int COUNTER = 10,                     // н•ҙлӢ№ мҲ«мһҗм—җ н•ҙлӢ№лҗҳлҠ” CLKк°Җ м§ҖлӮң мқҙнӣ„м—җлҠ” Counterк°Җ мҰқк°Җн•ҳм§Җ м•ҠмқҢ.
    parameter int BIT_COUNTER = $clog2(COUNTER),
    parameter int BIT_TABLE = TAG + BIT_COUNTER     // Tableмқҳ м „мІҙ bit мҲҳлҘј л°ҳнҷҳн•Ё.
)(
    // CLK, Reset
    input clk, rst_n,

    // CPU - Cache к°„ нҶөмӢ  кҙҖл Ё
    input             i_cpu_req, i_cpu_write,              // CPUлЎңл¶Җн„° req / write мӢ нҳёлҘј л°ӣмқҢ.
    input    [DATA_WIDTH-1:0]    i_cpu_wdata,              // CPUмңјлЎңл¶Җн„° DATAлҘј мқҪм–ҙмҷҖ Cellм—җ мҚЁм•ј н•Ё.
    input    [ADDR_WIDTH-1:0]    i_cpu_addr,               // CPUмңјлЎңл¶Җн„° Memoryмқҳ м–ҙлҠҗ мЈјмҶҢм—җ м“°кё°лҘј н•  кІғмқём§ҖлҘј кІ°м •н•ҳлҠ” н•ҙлӢ№ к°’мқ„ мӮ¬мҡ©н•ҳм—¬ Cache HIT/MISS м—¬л¶Җ нҷ•мқё.
    output reg  [DATA_WIDTH-1:0]    o_cpu_rdata,              // CPUм—җкІҢ м „лӢ¬н•ҙм•ј н•  Dataк°Җ м¶ңл ҘлҗҳлҠ” port   
          

    // Cache - DRAM(Memory)к°„ нҶөмӢ  кҙҖл Ё
    input                    i_mem_ack,                    // DRAMмңјлЎңл¶Җн„° ack мӢ нҳёлҘј л°ӣмқҢ.
    input   [DATA_WIDTH-1:0] i_mem_rdata,                  // DRAM лӮҙл¶Җмқҳ м •ліҙ л“Өкі  мҷҖм•јн•ҳлҜҖлЎң мһ…л ҘмңјлЎң м„Өм •.
    input   [ADDR_WIDTH-1:0] i_mem_raddr,             
    output reg [DATA_WIDTH-1:0] o_mem_wdata,                  // CPUк°Җ мҡ”мІӯмӢң Memoryмқҳ нҠ№м • addrм—җ м ҖмһҘлҗң DataлҘј Update мӢңмјңмӨҳм•ј н•Ё.
    output reg [ADDR_WIDTH-1:0] o_mem_waddr                                            
                                           
);
    
    // Address мһ…л Ҙ мӢ нҳёмқҳ л¶„лҰ¬. Tag + Index + Offset нҳ•нғңлЎң кө¬м„ұлҗЁ.

    wire    [INDEX-1:0] index_addr;
    wire    [OFFSET-1:0] offset_addr;
    wire    [TAG-1:0] tag_addr;


    wire    [INDEX-1:0] index_addr_mem;
    wire    [OFFSET-1:0] offset_addr_mem;
    wire    [TAG-1:0] tag_addr_mem;

    assign {tag_addr, index_addr, offset_addr} = i_cpu_addr;
    assign {tag_addr_mem, index_addr_mem, offset_addr_mem} = i_mem_raddr;

    // Vaild, Tag нҷ•мқё к°ҖлҠҘн•ң Tableмқ„ мғқм„ұн•Ё. мөңмғҒмң„ л№„нҠёлҠ” Vaild BitлЎң м„Өм •н•ҳм—¬ (Vaild + Counter + Tag) кө¬мЎ° мұ„нғқ.
    reg         [BIT_TABLE:0] table_reg[0:CELL_DEPTH-1];   

    // Match лҗҳлҠ”м§Җ, Vaildн•ңм§Җ нҷ•мқён•ҙм•ј н•ҳлҜҖлЎң, regм—җм„ң мӢ нҳё л”°лЎң л№јм„ң мғқм„ұн•Ё.
    wire        table_vaild[0:CELL_DEPTH-1];
    wire        [BIT_COUNTER-1:0] table_counter[0:CELL_DEPTH-1];
    wire        [TAG-1:0] table_tag[0:CELL_DEPTH-1];

    // generate мӮ¬мҡ©н•ҙм„ң к°Ғ index лі„лЎң мӢ нҳё м¶ңл Ҙ м„Өм •.
    genvar j;
    generate
        for (j=0; j<CELL_DEPTH; j++) begin
            assign {table_vaild[j], table_counter[j], table_tag[j]} = table_reg[j];
        end
    endgenerate

    // Cache HIT/MISS нҢҗлі„
    wire cache_HM;
    assign cache_HM = (tag_addr==table_tag[index_addr]) ? 1 : 0;    // 1 hit, 0 miss 

    // FSMмқҙ н•„мҡ”н•ң кІғмңјлЎң нҢҗлӢЁлҗҳм–ҙ Stateк°Җ н•„мҡ”н•Ё.
    reg [3:0]   now_state, next_state;
    

    //  кіөнҶө state
    localparam IDLE = 4'h0;

    //  Readмқҳ кІҪмҡ°
    localparam CACHE_CHECK = 4'h1;
    localparam READ_WAIT1 = 4'h2;
    localparam READ_WAIT2 = 4'h3;
    localparam SEND_CPU = 4'h4;

    localparam NEED_READ_DRAM = 4'h5;
    
    //  Writeмқҳ кІҪмҡ°
    localparam WRITE_UPDATE_CACHE = 4'h6;
    localparam NEED_WRITE_DRAM = 4'h7;


    // TPSRAM лӘЁл“Ҳмқ„ мң„н•ң wire мӨҖл№„

    wire [DATA_WIDTH-1:0] write_data_cache_w;
    wire [DATA_WIDTH-1:0] read_data_cache_w;

    reg [DATA_WIDTH-1:0] write_data_cache;
    reg [DATA_WIDTH-1:0] read_data_cache;

    assign write_data_cache_w = write_data_cache;
    assign read_data_cache_w = read_data_cache;

    wire we, re;
    assign we = !(cache_HM&&table_vaild[index_addr]) || i_cpu_write;       //  NEED_READ_DRAM мЎ°кұҙм—җ CPUк°Җ м§Ғм ‘ Writingн•ҳлҠ” н•ӯлӘ© м¶”к°Җ.
    assign re = (cache_HM&&table_vaild[index_addr]) || !i_mem_ack;         //  READ_WAIT мЎ°кұҙм—җ mem ackк°Җ 0мқҙл©ҙ read н•ҳм—¬ м¶ңл Ҙн•ҳлҠ” н•ӯлӘ©мһ„. 

    reg [ADDR_WIDTH-1:0] wa, ra;
    wire [ADDR_WIDTH-1:0] wa_w, ra_w;

    assign wa_w = wa;
    assign ra_w = ra;




    // Reset л“ұ Counter л¶Җл¶„мқ„ мқјлӢЁ лЁјм Җ кө¬нҳ„. REGлҘј Seq/Combм—җм„ң лҸҷмӢңм—җ мӮ¬мҡ©н•ҳл©ҙ м•Ҳ лҗҳкё° л•Ңл¬ём—җ м•„лһҳм—җ мЎ°кұҙ м¶”к°Җ.
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            for (int i=0; i<CELL_DEPTH; i++)  table_reg[i] <= 'h0; 
        end    

        else begin
            for (int i=0; i<CELL_DEPTH; i++)    begin
                if (table_vaild[i]==1)  begin
                    if (table_vaild[i]!=COUNTER)  table_reg[i][(TAG+BIT_COUNTER)-1:TAG] <= table_reg[i][(TAG+BIT_COUNTER)-1:TAG]+1; // Counter к°ұмӢ 
                    else table_reg[i][(TAG+BIT_COUNTER)-1:TAG] <= table_reg[i][(TAG+BIT_COUNTER)-1:TAG];
                end
                else table_reg[i] <= 'h0;    // мң нҡЁн•ҳм§Җ м•ҠмқҖ к°’мқҖ мӮӯм ң.
            end

            if (i_cpu_req||i_cpu_write)  now_state <= next_state;     
            else    now_state <= IDLE;

            if ((next_state==NEED_READ_DRAM) || (next_state==WRITE_UPDATE_CACHE)) begin
                table_reg[index_addr] <= {1'b1, {(BIT_COUNTER-1){1'b0}}, 1'b1, tag_addr}; 
            end

        end
    end


    // FSMм—җ л”°лқј Comb Logicмқҳ м¶ңл Ҙмқ„ кІ°м •н•  кІғ. 
    always @(*)  begin

        // мҙҲкё°к°’мқ„ лҜёлҰ¬ м§Җм •н•ҳкі  мӢңмһ‘н•ҳл©ҙм„ң LatchлҘј л°©м§Җн•ҳкё°.
        next_state = now_state;
        ra = 'h0;
        wa = 'h0;
        write_data_cache = 'h0;
        read_data_cache = 'h0;
        o_cpu_rdata = 'h0;
        o_mem_waddr = 'h0;
        o_mem_wdata = 'h0;

        case(now_state)
            default : begin
                    if (i_cpu_req)  next_state = CACHE_CHECK;  // кі„мҶҚ мјңм ёмһҲлӢӨл©ҙ лӢӨмқҢмңјлЎң м§„н–үн•Ё.
                    else next_state = now_state; // м•„лӢҲлқјл©ҙ мқҙм „ кІғмқ„ кі„мҶҚ м—…лҚ°мқҙнҠён•Ё.
                end
            CACHE_CHECK : begin 
                    if (cache_HM&&table_vaild[index_addr])   next_state = READ_WAIT1;       // Vaildн•ҳкі  Hit -> м •мғҒм ҒмңјлЎң Read кіјм • м§„н–ү к°ҖлҠҘ.
                    else next_state = NEED_READ_DRAM;                                      // Invaildн•ҳкұ°лӮҳ, Missмқё кІҪмҡ° -> DRAM м°ёмЎ°н•ҙм•ј н•Ё.
                end
            READ_WAIT1 : begin
                    next_state = READ_WAIT2;
                    ra = index_addr;
                end 
            READ_WAIT2 : begin
                    o_cpu_rdata = read_data_cache_w;
                    next_state = SEND_CPU;                    
                end
            SEND_CPU : begin
                    if (!i_cpu_req) begin       // CPUк°Җ лҚ” мқҙмғҒ н•ҙлӢ№ к°’мқҙ reqн•ҳм§Җ м•ҠлӢӨкі  ліҙлӮҙл©ҙ IDLE
                        next_state = IDLE;
                        ra = 'h0;
                        o_cpu_rdata = 0;
                    end
                    else next_state = SEND_CPU;    // кі„мҶҚ н•„мҡ”н•ҳл©ҙ кі„мҶҚ кіөкёүн•ҙмӨҢ (Pipelining н•  л•ҢлҠ” мҲҳм •н•ҙм•јн•Ё.)
                end
            NEED_READ_DRAM : begin
                    o_mem_waddr = i_cpu_addr;
                    o_mem_wdata = 'h0;
                    wa = i_mem_raddr;
                    if (i_mem_ack&&(next_state!=NEED_WRITE_DRAM))  begin       // DRAMм—җм„ң мқ‘лӢөн•ҳл©ҙ
                        o_cpu_rdata = i_mem_rdata; // Feed Forwarding
                        write_data_cache = i_mem_rdata;
                        next_state = SEND_CPU;
                        wa = 'h0;
                        o_mem_waddr = 'h0;
                    end
                    else next_state = NEED_READ_DRAM;

                end


            // WRITE
            WRITE_UPDATE_CACHE : begin
                if (i_cpu_write)  begin
                    write_data_cache = i_cpu_wdata; 
                    wa = index_addr;
                    next_state = NEED_WRITE_DRAM;
                end

                else next_state = WRITE_UPDATE_CACHE;
            end   

            NEED_WRITE_DRAM : begin
                if (!i_mem_ack)  begin   // update мҡ°м„ 
                    o_mem_wdata = i_cpu_wdata;
                    o_mem_waddr = i_cpu_addr;
                end
                else begin
                    wa = 0;
                    o_mem_waddr = 0;
                    o_mem_wdata = 0;
                    next_state = IDLE;
                end

            end
        endcase
    end









    // Module instance.
    tpsram #(DATA_WIDTH, CELL_DEPTH) sram_cell(
        .clk(clk),
        .wd(write_data_cache_w),  // data in (мһ…л Ҙ л°ӣмқҖ data write)
        .ra(ra_w),  // read address
        .wa(wa_w),  // write address
        .we(we),  // write enable
        .re(re),  // read enable

        .rd(read_data_cache_w)   // data out (cellм—җм„ң readн•ң data м¶ңл Ҙ)

    );



endmodule