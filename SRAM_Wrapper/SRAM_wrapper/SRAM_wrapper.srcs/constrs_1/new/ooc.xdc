# ---------------------------------------------------------------------------
# 1. 클럭 정의 (Clock Definition)
# OOC 모듈의 모든 클럭 포트에 반드시 정의해야 합니다.
# 10ns 주기 = 100MHz 동작 주파수
# ---------------------------------------------------------------------------
create_clock -period 10.000 -name clk -waveform {0.000 5.000} [get_ports clk]

# ---------------------------------------------------------------------------
# 2. 입출력 타이밍 예산 설정 (I/O Budgeting)
# 실제 핀 정보가 없으므로, 입출력 신호가 사용할 최대 지연 시간을 강제 지정합니다.
# 클럭 주기의 약 40~50%를 할당하여 설계 내부 마진을 확보하는 것이 관례입니다.
# ---------------------------------------------------------------------------
# 입력 포트 (cs, we, ad, din) -> 내부 레지스터까지의 최대 지연 시간
set_max_delay -from [get_ports {cs we ad[*] din[*]}] -to [all_registers -data_pins] -datapath_only 4.0

# 내부 레지스터 -> 출력 포트 (dout)까지의 최대 지연 시간
set_max_delay -from [all_registers -clock_pins] -to [get_ports {dout[*]}] -datapath_only 4.0

# ---------------------------------------------------------------------------
# 3. 클럭 불확실성 및 지터 설정 (Clock Uncertainty & Jitter)
# 상위 모듈에서 올 클럭의 흔들림을 미리 반영하여 더 가혹하게 테스트합니다.
# ---------------------------------------------------------------------------
set_system_jitter 0.0
set_clock_uncertainty 0.100 [get_clocks clk]
set_clock_latency -source -max 0.20 [get_clocks clk]